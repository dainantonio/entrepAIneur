{
  "entities": {
    "profile": {
      "title": "Business Profile",
      "description": "A detailed profile of an entrepreneur's business.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The Firebase Auth UID of the user"
        },
        "fullName": {
          "type": "string",
          "description": "The entrepreneur's full name"
        },
        "businessName": {
          "type": "string",
          "description": "The name of the business"
        },
        "vertical": {
          "type": "string",
          "description": "The industry or trade category"
        },
        "location": {
          "type": "string",
          "description": "The primary location of operations"
        },
        "whatsappNumber": {
          "type": "string",
          "description": "The phone number for WhatsApp integration"
        },
        "onboardingCompleted": {
          "type": "boolean",
          "description": "Whether the user has finished the onboarding flow"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the profile was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the profile was last updated"
        }
      },
      "required": ["uid", "fullName", "businessName", "vertical", "onboardingCompleted", "createdAt"]
    },
    "waitlist": {
      "title": "Waitlist Entry",
      "description": "A user who has joined the waitlist for EntrepAIneur products.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "business": {
          "type": "string",
          "description": "Description of the user's business"
        },
        "market": {
          "type": "string",
          "description": "The market or location of the business"
        },
        "productInterest": {
          "type": "string",
          "description": "The EntrepAIneur product they are interested in"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user joined the waitlist"
        }
      },
      "required": ["name", "email", "business", "createdAt"]
    },
    "posts": {
      "title": "Blog Post",
      "description": "A post for the EntrepAIneur insights blog.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the post"
        },
        "content": {
          "type": "string",
          "description": "The full content of the post in Markdown"
        },
        "excerpt": {
          "type": "string",
          "description": "A short summary of the post"
        },
        "author": {
          "type": "string",
          "description": "The author's name"
        },
        "image": {
          "type": "string",
          "description": "The URL of the cover image"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of tags for the post"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the post was published"
        }
      },
      "required": ["title", "content", "excerpt", "author", "createdAt"]
    },
    "feeds": {
      "title": "RSS Feed",
      "description": "An RSS feed URL to be displayed in the insights section.",
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "description": "The URL of the RSS feed"
        },
        "name": {
          "type": "string",
          "description": "The name or category of the feed"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the feed was added"
        }
      },
      "required": ["url", "name", "createdAt"]
    },
    "toolkit": {
      "title": "Toolkit Resource",
      "description": "A resource for the EntrepAIneur toolkit.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the resource"
        },
        "description": {
          "type": "string",
          "description": "A short description of the resource"
        },
        "type": {
          "type": "string",
          "enum": ["Prompt", "Template", "Guide", "Tool"],
          "description": "The category of the resource"
        },
        "content": {
          "type": "string",
          "description": "The actual content or link to the resource"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the resource was added"
        }
      },
      "required": ["title", "description", "type", "content", "createdAt"]
    },
    "market_intel": {
      "title": "Market Intelligence",
      "description": "Data point for the interactive market map.",
      "type": "object",
      "properties": {
        "region": {
          "type": "string",
          "enum": ["Tri-state", "Jamaica"],
          "description": "The region the intelligence belongs to"
        },
        "title": {
          "type": "string",
          "description": "The headline of the insight"
        },
        "description": {
          "type": "string",
          "description": "The detailed insight"
        },
        "coordinates": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "description": "Geographic coordinates for the map"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the insight was added"
        }
      },
      "required": ["region", "title", "description", "coordinates", "createdAt"]
    }
  },
  "firestore": {
    "waitlist": {
      "schema": "waitlist",
      "description": "Collection of waitlist signups"
    },
    "profiles": {
      "schema": "profile",
      "description": "User business profiles created during onboarding"
    },
    "posts": {
      "schema": "posts",
      "description": "Blog posts for entrepreneurial insights"
    },
    "feeds": {
      "schema": "feeds",
      "description": "Collection of RSS feed URLs"
    },
    "toolkit": {
      "schema": "toolkit",
      "description": "Gated resources for subscribers"
    },
    "market_intel": {
      "schema": "market_intel",
      "description": "Data for the interactive market map"
    }
  }
}
